# ============================================
# BROKERSEC BACKEND - Variables de Entorno
# ============================================

# Puerto del servidor
PORT=3001

# Base de datos PostgreSQL
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=12345
DB_NAME=brokersec
DATABASE_URL=postgresql://postgres:12345@localhost:5433/brokersec
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000

# JWT Secret (generar uno seguro en producción)
JWT_SECRET=brokersec-super-secret-key-2025-change-in-production
JWT_EXPIRE=7d

# Encriptación de contraseñas
BCRYPT_SALT_ROUNDS=10

# API externa - OpenWeatherMap
OPENWEATHER_API_KEY=TU_API_KEY_AQUI
OPENWEATHER_BASE_URL=https://api.openweathermap.org/data/2.5

# API OpenAI - Asistente virtual
OPENAI_API_KEY=NO_CONFIGURADA
OPENAI_MODEL=gpt-4.1-mini

# Seguridad
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
INTERNAL_API_KEY=brokersec-internal-api-key-2025
