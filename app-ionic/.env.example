# Configuracion de la API Backend
# En desarrollo web, si no defines VITE_API_URL, la app usara
# automaticamente http://<host-del-navegador>:3001.
# Define esta variable solo si quieres forzar otra URL:
VITE_API_URL=http://127.0.0.1:3001

# Para Android emulator:
VITE_API_URL_ANDROID=http://10.0.2.2:3001

# Para iOS simulator:
VITE_API_URL_IOS=http://127.0.0.1:3001

# Servidor de actualizaciones en tiempo real (Live Update)
# Configura la URL de tu servidor de actualizaciones
VITE_UPDATE_SERVER_URL=https://tu-servidor.com/api/updates

# Configuracion legacy (no se usa en este proyecto)
REACT_APP_API_URL=https://app.uea.edu.ec/
